model Workspaces {
  id        String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId     String        @map("org_id")
  name      String
  createdAt DateTime      @default(now()) @map("created_at")
  org       Organizations @relation(fields: [orgId], references: [id], onDelete: Cascade)

  monitors  Monitors[]
  scans     Scans[]
  assets    Assets[]
  alerts    Alerts[]
  incidents Incidents[]
  webhooks  Webhooks[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("workspaces")
}
