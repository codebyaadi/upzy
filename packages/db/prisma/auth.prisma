model Users {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean       @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  sessions      Sessions[]
  accounts      Accounts[]
  teammembers   TeamMembers[]
  members       Members[]
  invitations   Invitations[]
  auditLogs     AuditLogs[]

  @@unique([email])
  @@map("users")
}

model Sessions {
  id                   String   @id
  expiresAt            DateTime @map("expires_at")
  token                String
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  userId               String   @map("user_id")
  users                Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?  @map("active_organization_id")
  activeTeamId         String?  @map("active_team_id")

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Accounts {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  users                 Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("accounts")
}

model Verifications {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Organizations {
  id          String        @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime      @map("created_at")
  metadata    String?
  teams       Teams[]
  members     Members[]
  invitations Invitations[]
  apiKeys     ApiKeys[]
  auditLogs   AuditLogs[]
  workspaces  Workspaces[]

  @@unique([slug])
  @@map("organizations")
}

model Teams {
  id             String        @id
  name           String
  organizationId String        @map("organization_id")
  organizations  Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")
  teammembers    TeamMembers[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMembers {
  id        String    @id
  teamId    String    @map("team_id")
  teams     Teams     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  users     Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime? @map("created_at")

  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model Members {
  id             String        @id
  organizationId String        @map("organization_id")
  organizations  Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String        @map("user_id")
  users          Users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String        @default("member")
  createdAt      DateTime      @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

model Invitations {
  id             String        @id
  organizationId String        @map("organization_id")
  organizations  Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  teamId         String?       @map("team_id")
  status         String        @default("pending")
  expiresAt      DateTime      @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  inviterId      String        @map("inviter_id")
  users          Users         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}
