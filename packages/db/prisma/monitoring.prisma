model Monitors {
  id          String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  name        String
  type        MonitorType
  target      String
  interval    Int
  active      Boolean
  workspace   Workspaces  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now()) @map("created_at")

  monitorChecks MonitorChecks[]

  @@map("monitors")
}

model MonitorChecks {
  id         String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  monitorId  String      @map("monitor_id") @db.Uuid
  status     CheckStatus
  responseMs Int?        @map("response_ms")
  createdAt  DateTime    @default(now()) @map("created_at")
  region     String?
  monitor    Monitors    @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@map("monitor_checks")
}

enum MonitorType {
  http
  tcp
  dns
  ssl
  synthetic
}

enum CheckStatus {
  up
  down
  unknown
}
