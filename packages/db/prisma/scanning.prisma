model Scans {
  id          String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  name        String
  type        ScanType
  status      ScanStatus
  startedAt   DateTime?  @map("started_at")
  finishedAt  DateTime?  @map("finished_at")
  triggeredBy String?    @map("triggered_by")
  workspace   Workspaces @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  findings Findings[]

  @@map("scans")
}

model Findings {
  id          String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  scanId      String        @map("scan_id") @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  severity    Severity
  title       String
  description String
  status      FindingStatus
  createdAt   DateTime      @default(now()) @map("created_at")
  scan        Scans         @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("findings")
}

enum ScanType {
  assetDiscovery
  portScan
  vulnScan
  custom
}

enum ScanStatus {
  queued
  running
  completed
  failed
}

enum Severity {
  critical
  high
  medium
  low
  info
}

enum FindingStatus {
  open
  resolved
  ignored
}
